    "icons": [
        {
            "type": "menu",
            "menu_id": "water_box_mode",
            "icon_id": "water_level",
            "unique_id_regex": "water_level_",
            "available_values_attribute": "options",
            "icon": "mdi:water",
            "icon_mapping": {
                "low": "mdi:water-minus",
                "middle": "mdi:water",
                "high": "mdi:water-plus"
            },
            "tap_action": {
                "action": "call-service",
