{
    "map_modes": {
        "default_templates": ["vacuum_clean_zone"],
        "templates": {
            "vacuum_clean_zone": {
                "name": "map_mode.vacuum_clean_zone",
                "icon": "mdi:select-drag",
                "selection_type": "MANUAL_RECTANGLE",
                "max_selections": 5,
                "coordinates_rounding": true,
                "coordinates_to_meters_divider": 1000,
                "repeats_type": "NONE",
                "service_call_schema": {
                    "service": "neatsvor.vacuum_clean_zone",
                    "service_data": {
                        "entity_id": "[[entity_id]]",
                        "zones": "[[selection]]"
                    }
                }
            }
        }
    },
    "tiles": {
