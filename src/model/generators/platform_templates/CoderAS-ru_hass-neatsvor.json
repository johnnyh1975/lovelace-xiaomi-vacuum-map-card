                "unit": "unit.percent_shortcut"
            },
            {
                "tile_id": "side_brush_left",
                "unique_id_regex": "side_brush_",
                "icon": "mdi:brush",
                "label": "tile.side_brush_left.label",
                "unit": "unit.percent_shortcut"
            },
            {
                "tile_id": "filter_left",
                "icon": "mdi:air-filter",
                "unique_id_regex": "hepa_filter_",
                "label": "tile.filter_left.label",
                "unit": "unit.percent_shortcut"
            },
            {
                "tile_id": "cleaning_count",
                "icon": "mdi:counter",
                "unique_id_regex": "total_cleanings_",
                "label": "tile.cleaning_count.label"
            },
            {
                "tile_id": "cleaned_area",
