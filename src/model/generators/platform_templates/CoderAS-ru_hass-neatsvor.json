            "icon": "mdi:vacuum",
            "icon_mapping": {
                "sweep": "mdi:broom",
                "mop": "mdi:spray",
                "sweepMop": "mdi:vacuum-outline"
            },
            "tap_action": {
                "action": "call-service",
                "service": "select.select_option",
                "service_data": {
                    "option": "[[value]]",
                    "entity_id": "[[entity_id]]"
                }
            }
        }
